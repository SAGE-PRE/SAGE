{
  "protocol": "DHCP",
  "description": "Dynamic Host Configuration Protocol (RFC 2131)",
  "boundary_type": "dynamic",
  "fields": [
    {
      "name": "op",
      "type": "uint8",
      "offset": 0,
      "size": 1,
      "description": "Opcode: 1=request (BOOTREQUEST), 2=response (BOOTREPLY)"
    },
    {
      "name": "htype",
      "type": "uint8",
      "offset": 1,
      "size": 1,
      "description": "Hardware type: 1=Ethernet"
    },
    {
      "name": "hlen",
      "type": "uint8",
      "offset": 2,
      "size": 1,
      "description": "Hardware address length: 6 (Ethernet MAC)"
    },
    {
      "name": "hops",
      "type": "uint8",
      "offset": 3,
      "size": 1,
      "description": "Hop count (used by relay agents)"
    },
    {
      "name": "xid",
      "type": "uint32_be",
      "offset": 4,
      "size": 4,
      "description": "Transaction ID"
    },
    {
      "name": "secs",
      "type": "uint16_be",
      "offset": 8,
      "size": 2,
      "description": "Seconds since client boot"
    },
    {
      "name": "flags",
      "type": "uint16_be",
      "offset": 10,
      "size": 2,
      "description": "Flags: bit0=broadcast flag"
    },
    {
      "name": "ciaddr",
      "type": "uint32_be",
      "offset": 12,
      "size": 4,
      "description": "Client IPaddress"
    },
    {
      "name": "yiaddr",
      "type": "uint32_be",
      "offset": 16,
      "size": 4,
      "description": "IP address assigned to client"
    },
    {
      "name": "siaddr",
      "type": "uint32_be",
      "offset": 20,
      "size": 4,
      "description": "Next boot server IP address"
    },
    {
      "name": "giaddr",
      "type": "uint32_be",
      "offset": 24,
      "size": 4,
      "description": "Relay agent IP address"
    },
    {
      "name": "chaddr",
      "type": "bytes",
      "offset": 28,
      "size": 16,
      "description": "Client hardware address (MAC + padding)"
    },
    {
      "name": "sname",
      "type": "bytes",
      "offset": 44,
      "size": 64,
      "description": "Server hostname"
    },
    {
      "name": "file",
      "type": "bytes",
      "offset": 108,
      "size": 128,
      "description": "Boot file name"
    },
    {
      "name": "magic_cookie",
      "type": "uint32_be",
      "offset": 236,
      "size": 4,
      "description": "Magic cookie, fixed value 0x63825363"
    },
    {
      "name": "options",
      "type": "dhcp_options",
      "offset": 240,
      "size": "@total_length - 240",
      "description": "DHCP options (TLV format: type(1) + len(1) + value, ends with 0xFF)"
    }
  ],
  "test_cases": [
    {
      "case_id": "dhcp_discover",
      "parsed_values": {
        "op": 1,
        "htype": 1,
        "hlen": 6,
        "hops": 0,
        "magic_cookie": "0x63825363"
      },
      "boundaries": [0, 1, 2, 3, 4, 8, 10, 12, 16, 20, 24, 28, 44, 108, 236, 240],
      "description": "DHCP Discoverrequest"
    }
  ],
  "notes": [
    "DHCP is the IP address auto-allocation protocol in TCP/IP networks, RFC 2131",
    "Extended from BOOTP protocol, fixed 236-byte header",
    "Magic cookie (0x63825363) identifies the start of DHCP options",
    "Options use TLV format: type(1 byte) + length(1 byte) + value",
    "Common options: 53=Message type, 55=Parameter request list, 61=Client identifier",
    "Options end with 0xFF (End)"
  ]
}