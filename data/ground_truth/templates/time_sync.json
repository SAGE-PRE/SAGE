{
  "protocol": "TimeSync (TSYNC)",
  "description": "Virtual time synchronization protocol - fixed 32 bytes, big-endian",
  "boundary_type": "static",
  "total_length": 32,
  "fields": [
    {
      "name": "magic",
      "type": "uint16_be",
      "offset": 0,
      "size": 2,
      "description": "Protocol magic number, fixed value 0xABCD"
    },
    {
      "name": "version",
      "type": "uint8",
      "offset": 2,
      "size": 1,
      "description": "Protocol version, currently 0x01"
    },
    {
      "name": "msg_type",
      "type": "uint8",
      "offset": 3,
      "size": 1,
      "description": "Message type：0x01=sync request, 0x02=sync response, 0x03=delay request, 0x04=delay response"
    },
    {
      "name": "client_id",
      "type": "uint32_be",
      "offset": 4,
      "size": 4,
      "description": "Client ID (big-endian)"
    },
    {
      "name": "timestamp_sec",
      "type": "uint64_be",
      "offset": 8,
      "size": 8,
      "description": "Second-level Unix timestamp (big-endian)"
    },
    {
      "name": "timestamp_nsec",
      "type": "uint32_be",
      "offset": 16,
      "size": 4,
      "description": "Nanosecond part (big-endian, 0-999999999)"
    },
    {
      "name": "stratum",
      "type": "uint8",
      "offset": 20,
      "size": 1,
      "description": "Time stratum：0=client request, 1=primary server, 2+=secondary server"
    },
    {
      "name": "precision",
      "type": "int8",
      "offset": 21,
      "size": 1,
      "description": "Precision exponent (power of 2, e.g., -20 means precision is 2^-20 seconds)"
    },
    {
      "name": "reserved",
      "type": "bytes",
      "offset": 22,
      "size": 8,
      "description": "Reserved field, padded with 0x00"
    },
    {
      "name": "crc16",
      "type": "uint16_be",
      "offset": 30,
      "size": 2,
      "description": "CRC16 checksum (CCITT polynomial 0x1021, big-endian)"
    }
  ],
  "static_boundaries": [0, 2, 3, 4, 8, 16, 20, 21, 22, 30, 32],
  "msg_types": {
    "0x01": {
      "name": "MSG_SYNC_REQUEST",
      "description": "sync request",
      "typical_stratum": 0,
      "typical_precision": -18
    },
    "0x02": {
      "name": "MSG_SYNC_RESPONSE",
      "description": "sync response",
      "typical_stratum": 1,
      "typical_precision": -20
    },
    "0x03": {
      "name": "MSG_DELAY_REQUEST",
      "description": "Delay measurement request",
      "typical_stratum": 0,
      "typical_precision": -18
    },
    "0x04": {
      "name": "MSG_DELAY_RESPONSE",
      "description": "Delay measurement response",
      "typical_stratum": 1,
      "typical_precision": -20
    }
  },
