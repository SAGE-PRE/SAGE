      "parsed_values": {
        "magic": "0xCAFE",
        "version": 1,
        "msg_type": "0x10",
        "sequence": 0,
        "length": 2,
        "payload": {
          "sensor_id": "0x1003"
        },
        "checksum": "0xDBDF"
      },
      "boundaries": [0, 2, 3, 4, 8, 10, 12],
