{
  "protocol": "CustomIoT (CIOT)",
  "description": "Custom IoT sensor data transport protocol - a virtual protocol designed for testing LLM reverse engineering capabilities",
  "boundary_type": "dynamic",
  "fields": [
    {
      "name": "magic",
      "type": "uint16_be",
      "offset": 0,
      "size": 2,
      "description": "Protocol magic number, fixed value 0xCAFE"
    },
    {
      "name": "version",
      "type": "uint8",
      "offset": 2,
      "size": 1,
      "description": "Protocol version number, currently 0x01"
    },
    {
      "name": "msg_type",
      "type": "uint8",
      "offset": 3,
      "size": 1,
      "description": "Message type：0x10=temperature request, 0x11=temperature response, 0x20=humidity request, 0x21=humidity response, 0x30=status request, 0x31=status response"
    },
    {
      "name": "sequence",
      "type": "uint32_be",
      "offset": 4,
      "size": 4,
      "description": "Incremental sequence number"
    },
    {
      "name": "length",
      "type": "uint16_be",
      "offset": 8,
      "size": 2,
      "description": "Payload length (in bytes)"
    },
    {
      "name": "payload",
      "type": "struct",
      "offset": 10,
      "size": "@length",
      "description": "Variable-length payload data, structure varies based on msg_type",
      "payload_structures": {
        "0x10": {
          "name": "temp_request_payload",
          "description": "Temperature read request payload",
          "fields": [
            {"name": "sensor_id", "type": "uint16_be", "offset": 0, "size": 2, "description": "Sensor ID"}
          ]
        },
        "0x11": {
          "name": "temp_response_payload",
          "description": "Temperature read response payload",
          "fields": [
            {"name": "sensor_id", "type": "uint16_be", "offset": 0, "size": 2, "description": "Sensor ID"},
            {"name": "temperature", "type": "int16_be", "offset": 2, "size": 2, "description": "Temperature value (0.01°C unit)"}
          ]
        },
        "0x20": {
          "name": "humid_request_payload",
          "description": "Humidity read request payload",
          "fields": [
            {"name": "sensor_id", "type": "uint16_be", "offset": 0, "size": 2, "description": "Sensor ID"}
          ]
        },
        "0x21": {
          "name": "humid_response_payload",
          "description": "Humidity read response payload",
          "fields": [
            {"name": "sensor_id", "type": "uint16_be", "offset": 0, "size": 2, "description": "Sensor ID"},
            {"name": "humidity", "type": "uint8", "offset": 2, "size": 1, "description": "Humidity percentage (0-100)"}
          ]
        },
        "0x30": {
          "name": "status_request_payload",
          "description": "Status query request payload",
          "fields": [
            {"name": "sensor_id", "type": "uint16_be", "offset": 0, "size": 2, "description": "Sensor ID"}
          ]
        },
        "0x31": {
          "name": "status_response_payload",
          "description": "Status query response payload",
          "fields": [
            {"name": "sensor_id", "type": "uint16_be", "offset": 0, "size": 2, "description": "Sensor ID"},
            {"name": "status", "type": "uint8", "offset": 2, "size": 1, "description": "Status code：0=idle, 1=active, 2=error"},
            {"name": "battery", "type": "uint8", "offset": 3, "size": 1, "description": "Battery percentage (0-100)"}
          ]
        }
      }
    },
    {
      "name": "checksum",
      "type": "uint16_be",
      "offset": "$payload#",
      "size": 2,
      "description": "XOR checksum (XOR all bytes except checksum as 16-bit words)"
    }
  ],
  "test_cases": [
    {
