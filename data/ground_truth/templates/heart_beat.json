{
  "protocol": "HeartBeat (HBEAT)",
  "description": "Virtual heartbeat monitoring protocol - fixed 24 bytes, little-endian, for node health status monitoring",
  "boundary_type": "static",
  "total_length": 24,
  "fields": [
    {
      "name": "sync_word",
      "type": "uint16_le",
      "offset": 0,
      "size": 2,
      "description": "Sync word, fixed value 0xFACE (stored as CE FA in little-endian)"
    },
    {
      "name": "version",
      "type": "uint8",
      "offset": 2,
      "size": 1,
      "description": "Protocol version, currently 0x02"
    },
    {
      "name": "node_type",
      "type": "uint8",
      "offset": 3,
      "size": 1,
      "description": "Node type: 0x01=Master, 0x02=Slave, 0x03=Monitor, 0x04=Gateway"
    },
    {
      "name": "node_id",
      "type": "uint32_le",
      "offset": 4,
      "size": 4,
      "description": "Node ID (little-endian)"
    },
    {
      "name": "sequence",
      "type": "uint32_le",
      "offset": 8,
      "size": 4,
      "description": "Message sequence number (little-endian), increments with each send"
    },
    {
      "name": "uptime",
      "type": "uint32_le",
      "offset": 12,
      "size": 4,
      "description": "Node uptime (little-endian, in seconds)"
    },
    {
      "name": "cpu_load",
      "type": "uint8",
      "offset": 16,
      "size": 1,
      "description": "CPU load percentage (0-100)"
    },
    {
      "name": "mem_load",
      "type": "uint8",
      "offset": 17,
      "size": 1,
      "description": "Memory load percentage (0-100)"
    },
    {
      "name": "status",
      "type": "uint8",
      "offset": 18,
      "size": 1,
      "description": "Status code: 0x00=OK, 0x01=WARN, 0x02=ERROR, 0x03=CRITICAL"
    },
    {
      "name": "flags",
      "type": "uint8",
      "offset": 19,
      "size": 1,
      "description": "Flags: bit0=attention required"
    },
    {
      "name": "crc32",
      "type": "uint32_le",
      "offset": 20,
      "size": 4,
      "description": "CRC32 checksum (little-endian), calculated for the first 20 bytes"
    }
  ],
  "static_boundaries": [0, 2, 3, 4, 8, 12, 16, 17, 18, 19, 20, 24],
  "node_types": {
    "0x01": {
      "name": "NODE_MASTER",
      "description": "Master node, responsible for coordination and management"
    },
    "0x02": {
      "name": "NODE_SLAVE",
      "description": "Slave node, executes work tasks"
    },
    "0x03": {
      "name": "NODE_MONITOR",
      "description": "Monitor node, collects status information"
    },
    "0x04": {
      "name": "NODE_GATEWAY",
      "description": "Gateway node, responsible for network boundary communication"
    }
  },
  "status_codes": {
    "0x00": {
      "name": "STATUS_OK",
      "description": "Normal operation",
      "condition": "CPU and memory load both below 70%"
    },
    "0x01": {
      "name": "STATUS_WARN",
      "description": "Warning status",
      "condition": "CPU or memory load between 70%-80%"
    },
    "0x02": {
      "name": "STATUS_ERROR",
      "description": "Error status",
      "condition": "CPU or memory load between 80%-90%"
    },
    "0x03": {
      "name": "STATUS_CRITICAL",
      "description": "Critical status",
      "condition": "CPU or memory load exceeds 90%"
    }
  },
